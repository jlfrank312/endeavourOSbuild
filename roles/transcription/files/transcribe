#!/mnt/alter/Models/whisper/venv/bin/python
"""
transcribe — local video/audio transcription via faster-whisper + ffmpeg

Usage:
  transcribe <input_file> [--output PATH] [--model MODEL] [--language LANG]

Options:
  --output PATH     Output file path. Accepts a full path including filename,
                    or a directory (transcript is written there as
                    <input_basename>.txt). Defaults to alongside the input.
  --model MODEL     Whisper model size to load.
                    Choices: tiny, base, small, medium, large-v3
                    Default: large-v3
  --language LANG   BCP-47 source language code (e.g. en, ja, fr, de).
                    Omit to let Whisper auto-detect.

Output:
  A .txt file. Each line: [HH:MM:SS.mmm --> HH:MM:SS.mmm]  <text>

Examples:
  transcribe lecture.mp4
  transcribe lecture.mp4 --output ~/Documents/lecture.txt
  transcribe lecture.mp4 --output ~/Documents/
  transcribe interview.mkv --model medium
  transcribe film.mp4 --language ja
"""

import os
import sys

# ---------------------------------------------------------------------------
# CUDA compatibility shim — must execute before ctranslate2 is imported.
#
# ctranslate2 may have CUDA 12 library paths hard-coded while CachyOS ships
# CUDA 13.  If /opt/cuda/targets/x86_64-linux/lib is absent from
# LD_LIBRARY_PATH, prepend it and re-exec so the dynamic linker resolves
# libcuda from the correct tree on the very first shared-library load.
# Becomes a no-op once ctranslate2 ships native CUDA 13 support.
# ---------------------------------------------------------------------------
_CUDA_COMPAT = "/opt/cuda/targets/x86_64-linux/lib"
if os.path.isdir(_CUDA_COMPAT) and _CUDA_COMPAT not in os.environ.get("LD_LIBRARY_PATH", "").split(":"):
    os.environ["LD_LIBRARY_PATH"] = ":".join(
        filter(None, [_CUDA_COMPAT, os.environ.get("LD_LIBRARY_PATH", "")])
    )
    os.execv(sys.executable, [sys.executable] + sys.argv)
del _CUDA_COMPAT

import argparse
import subprocess
import tempfile
from pathlib import Path

MODELS_DIR = "/mnt/alter/Models/whisper"
DEFAULT_MODEL = "large-v3"
MODEL_CHOICES = ["tiny", "base", "small", "medium", "large-v3"]


def die(msg: str) -> None:
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(1)


def extract_audio(video_path: Path, tmpdir: str) -> str:
    """Extract a 16 kHz mono WAV from the input file using ffmpeg."""
    audio_path = os.path.join(tmpdir, "audio.wav")
    result = subprocess.run(
        [
            "ffmpeg", "-y",
            "-i", str(video_path),
            "-ar", "16000",
            "-ac", "1",
            "-c:a", "pcm_s16le",
            audio_path,
            "-loglevel", "error",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        die(f"ffmpeg failed:\n{result.stderr.strip()}")
    return audio_path


def fmt_ts(seconds: float) -> str:
    """Format a float second count as HH:MM:SS.mmm."""
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = seconds % 60
    return f"{h:02d}:{m:02d}:{s:06.3f}"


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Transcribe video/audio dialogue to a timestamped text file.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("input", help="Path to the video or audio file")
    parser.add_argument(
        "--output",
        default=None,
        metavar="PATH",
        help="Output path: a .txt filename or a directory. "
             "Defaults to alongside the input file.",
    )
    parser.add_argument(
        "--model",
        default=DEFAULT_MODEL,
        choices=MODEL_CHOICES,
        metavar="MODEL",
        help=f"Whisper model size (default: {DEFAULT_MODEL}). "
             f"Choices: {', '.join(MODEL_CHOICES)}",
    )
    parser.add_argument(
        "--language",
        default=None,
        metavar="LANG",
        help="Source language code, e.g. 'en', 'ja'. Omit to auto-detect.",
    )
    args = parser.parse_args()

    input_path = Path(args.input).resolve()
    if not input_path.exists():
        die(f"file not found: {input_path}")

    if not Path(MODELS_DIR).exists():
        die(
            f"Models directory not found: {MODELS_DIR}\n"
            "  Is the alter partition mounted?  Try: mountpoint /mnt/alter"
        )

    if args.output is None:
        output_path = input_path.with_suffix(".txt")
    else:
        specified = Path(args.output).expanduser().resolve()
        if specified.is_dir():
            output_path = specified / input_path.with_suffix(".txt").name
        else:
            output_path = specified
            if output_path.suffix != ".txt":
                die(f"output path must end in .txt, got: {output_path}")
            output_path.parent.mkdir(parents=True, exist_ok=True)

    print(f"  Input  : {input_path}")
    print(f"  Output : {output_path}")
    print(f"  Model  : {args.model}")
    print(f"  Lang   : {args.language or 'auto-detect'}")
    print()

    # Deferred import keeps --help fast and gives a clean error if the
    # venv is broken rather than a confusing ImportError at startup.
    try:
        from faster_whisper import WhisperModel
    except ImportError:
        die(
            "faster-whisper not importable. Venv may need to be rebuilt.\n"
            "  Run the Ansible playbook to reprovision the transcription role."
        )

    print("Loading model…", flush=True)
    model = WhisperModel(
        args.model,
        device="cuda",
        compute_type="float16",
        download_root=MODELS_DIR,
    )

    with tempfile.TemporaryDirectory() as tmpdir:
        print("Extracting audio…", flush=True)
        audio_path = extract_audio(input_path, tmpdir)

        print("Transcribing…", flush=True)
        segments, info = model.transcribe(
            audio_path,
            language=args.language,
            beam_size=5,
            word_timestamps=False,
            vad_filter=True,
            vad_parameters={"min_silence_duration_ms": 500},
        )

        print(
            f"  Detected language: {info.language} "
            f"({info.language_probability:.1%} confidence)\n",
            flush=True,
        )

        with open(output_path, "w", encoding="utf-8") as f:
            for segment in segments:
                line = (
                    f"[{fmt_ts(segment.start)} --> {fmt_ts(segment.end)}]"
                    f"  {segment.text.strip()}"
                )
                print(line, flush=True)
                f.write(line + "\n")

    print(f"\nSaved: {output_path}")


if __name__ == "__main__":
    main()
