# /etc/tlp.conf - Managed by Ansible

# CPU Management (Ceded to auto-cpufreq)
CPU_SCALING_GOVERNOR_ON_AC=
CPU_SCALING_GOVERNOR_ON_BAT=
CPU_ENERGY_PERF_POLICY_ON_AC=
CPU_ENERGY_PERF_POLICY_ON_BAT=

# Battery Charge Thresholds
{% if global_supports_charge_threshold | default(false) %}
START_CHARGE_THRESH_BAT0={{ tlp_charge_start | default(75) }}
STOP_CHARGE_THRESH_BAT0={{ tlp_charge_stop | default(80) }}
{% else %}
# Hardware does not support battery charge thresholds via sysfs.
{% endif %}

# Power Savings
USB_AUTOSUSPEND=1
PCIE_ASPM_ON_AC=default
PCIE_ASPM_ON_BAT=powersupersave

# Runtime power management
RUNTIME_PM_ON_AC=on
RUNTIME_PM_ON_BAT=auto

# Intel GPU frequency — prevents stutter on iGPU under TLP
INTEL_GPU_MIN_FREQ_ON_AC=500
INTEL_GPU_MIN_FREQ_ON_BAT=500